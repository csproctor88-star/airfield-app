# Supabase — Required for database, auth, storage, and realtime
# Leave blank or remove to run in demo mode with offline mock data
NEXT_PUBLIC_SUPABASE_URL=https://[project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[anon-key]
SUPABASE_SERVICE_ROLE_KEY=[service-role-key]

# Mapbox — Required for interactive maps and satellite imagery
# Free tier: 50,000 map loads/month — https://mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=[mapbox-token]

# App URL — Used for auth redirect URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Elevation API — Used for obstruction ground elevation lookups
# Enable "Elevation API" in Google Cloud Console — $5 per 1,000 requests
GOOGLE_ELEVATION_API_KEY=[google-api-key]

# Resend — Required for email PDF delivery
# https://resend.com — free tier: 100 emails/day
RESEND_API_KEY=[resend-api-key]

# Kiosk auto-login — shared password used by /kiosk/<icao> URLs.
# Server-side only (not prefixed with NEXT_PUBLIC_). Kiosk accounts are
# provisioned lazily on first hit. Pick a long random string; rotate by
# updating Vercel env var AND the password on existing auth.users rows
# in the Supabase dashboard.
KIOSK_PASSWORD=[long-random-string]
